VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# 本機腳本連線（擇一）：
# A) 建議：Database 頁「Connection string」整段 URI（可選 Pooler，避免 ENOTFOUND）：
#    SUPABASE_DATABASE_URL=postgresql://postgres:密碼@主機:埠/postgres
# B) 或：SUPABASE_DB_PASSWORD=（密碼含空格請用雙引號包住）+ 專案 VITE_SUPABASE_URL
# 勿把密碼或 URI 提交到 Git；用 .env.local
