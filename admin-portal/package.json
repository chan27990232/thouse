{
  "name": "thouse-admin-portal",
  "description": "簡屋管理後台（Web / 桌面版）",
  "author": "Thouse",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:3010 && cross-env ELECTRON_START_URL=http://127.0.0.1:3010 electron .\"",
    "build": "tsc -b && vite build",
    "start:desktop": "electron .",
    "build:desktop": "tsc -b && vite build && npx cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "express": "^4.21.0",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.thouse.admin",
    "productName": "Thouse Admin",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "forceCodeSigning": false,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    }
  }
}
